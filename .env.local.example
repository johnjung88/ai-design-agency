# AIO 사이트 (aio-make.com) 환경변수 예시
# 사용법: 이 파일을 .env.local 로 복사 후 값 채우기

# === 사이트 ===
NEXT_PUBLIC_SITE_URL=https://aio-make.com

# === Supabase (단일 프로젝트 사용) ===
# Supabase Dashboard → Settings → API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Admin 인증 ===
ADMIN_PASSWORD=
# 32자 이상 랜덤 문자열 권장
ADMIN_SESSION_SECRET=

# === Anthropic (챗봇) ===
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# === Telegram (양방향 봇 + cron 알림) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=7668768088
# 텔레그램 webhook 인증용 (사이트 → 봇)
TELEGRAM_WEBHOOK_SECRET=

# === Resend (메일 발송) ===
RESEND_API_KEY=
RESEND_FROM_EMAIL=AIO Agency <onboarding@resend.dev>
CONTACT_TO_EMAIL=aiomake2023@gmail.com

# === Cron 보안 (Vercel cron 인증) ===
# 32자 이상 랜덤 문자열 (Vercel이 cron 호출 시 Bearer 헤더로 전달)
# 생성: PowerShell에서 [Convert]::ToHexString([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32)).ToLower()
CRON_SECRET=
